	(model "${KIPRJMOD}/libs/custom_footprints/node_mcu.pretty/models/NODEMCU-32S.step"
		(offset
			(xyz 0 0 0)
		)
		(scale
			(xyz 1 1 1)
		)
		(rotate
			(xyz -90 -0 -0)
		)
	)
)
